{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "TripOpt: Train Agent",
            "type": "debugpy",
            "request": "launch",
            "module": "tripoptgym.scripts.main",
            "console": "integratedTerminal",
            "args": [
                "train",
                "--csv",
                "route_data.csv",
                "--start",
                "18",
                "--end",
                "22",
                "--checkpoint-interval",
                "100",
                "--target-score",
                "5000"
            ],
            "justMyCode": true
        },
        {
            "name": "TripOpt: Resume Training",
            "type": "debugpy",
            "request": "launch",
            "module": "tripoptgym.scripts.main",
            "console": "integratedTerminal",
            "args": [
                "train",
                "--csv",
                "route_data.csv",
                "--resume",
                "checkpoint_ep10.pth",
                "--episodes",
                "1000",
                "--checkpoint-interval",
                "5",
                "--start",
                "18",
                "--end",
                "22",
                "--target-score",
                "1200"
            ],
            "justMyCode": true
        },
        {
            "name": "TripOpt: Demo Video with Trained Agent",
            "type": "debugpy",
            "request": "launch",
